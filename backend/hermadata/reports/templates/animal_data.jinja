<div style="position: relative; height: 160px; margin: 16px 0 24px 0; page-break-inside: avoid;">
    <table style="position: absolute; left: 5%; width: 42%;">
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Nome</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.name }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Razza</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.breed }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Sesso</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.sex }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Età</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.age }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Data di nascita</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.birth_date }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Codice chip</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.chip_code }}</td></tr>
    </table>
    <table style="position: absolute; right: 5%; width: 42%;">
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Manto</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.fur_type }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Colore</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.fur_color }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Arrivato da</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.origin_city }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Arrivato il</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.entry_date }}</td></tr>
        <tr><td style="font-weight: bold; padding: 2px 8px 2px 0; border-bottom: 1px solid #000;">Taglia</td><td style="padding: 2px 0; border-bottom: 1px solid #000;">{{ animal.size }}</td></tr>
    </table>
</div>
